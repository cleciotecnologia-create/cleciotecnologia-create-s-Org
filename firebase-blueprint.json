{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "login": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "CONDO_ADMIN", "RESIDENT"] },
        "condoId": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Condo": {
      "title": "Condo",
      "description": "Condominium information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "units": { "type": "number" },
        "planId": { "type": "string", "enum": ["BASIC", "PRO", "PREMIUM"] },
        "subscriptionStatus": { "type": "string", "enum": ["ACTIVE", "PAST_DUE", "CANCELED"] },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "planId", "adminId"]
    },
    "Resident": {
      "title": "Resident",
      "description": "Resident of a condominium",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "block": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "login": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }
      },
      "required": ["id", "condoId", "name", "unit"]
    },
    "Occurrence": {
      "title": "Occurrence",
      "description": "Condominium occurrence or issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "residentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "IN_PROGRESS", "RESOLVED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "condoId", "residentId", "title", "status"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "Visitor authorized by a resident",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "residentId": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "type": { "type": "string", "enum": ["VISITOR", "SERVICE", "DELIVERY"] },
        "status": { "type": "string", "enum": ["PENDING", "AUTHORIZED", "EXPIRED"] },
        "validUntil": { "type": "string", "format": "date-time" },
        "qrCode": { "type": "string" }
      },
      "required": ["id", "condoId", "residentId", "name", "type", "status", "validUntil"]
    },
    "AccessLog": {
      "title": "AccessLog",
      "description": "Log of entry/exit events",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "visitorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string", "enum": ["ENTRY", "EXIT"] }
      },
      "required": ["id", "condoId", "visitorId", "timestamp", "action"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Real-time chat message between residents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "condoId", "senderId", "senderName", "text", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log of administrative actions for audit trail",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "resourceType": { "type": "string", "enum": ["RESIDENT", "CONDO", "PAYMENT", "OCCURRENCE", "VISITOR", "ASSEMBLY", "MAINTENANCE"] },
        "resourceId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "condoId", "userId", "userName", "action", "resourceType", "timestamp"]
    },
    "Package": {
      "title": "Package",
      "description": "Package delivery tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "residentId": { "type": "string" },
        "residentName": { "type": "string" },
        "unit": { "type": "string" },
        "description": { "type": "string" },
        "carrier": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "DELIVERED", "RETURNED"] },
        "receivedAt": { "type": "string", "format": "date-time" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "qrCodeData": { "type": "string" }
      },
      "required": ["id", "condoId", "residentId", "residentName", "unit", "status", "receivedAt"]
    },
    "Assembly": {
      "title": "Assembly",
      "description": "Digital assembly and voting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["SCHEDULED", "ACTIVE", "CLOSED"] },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "condoId", "title", "status", "startDate", "endDate"]
    },
    "MaintenanceTask": {
      "title": "MaintenanceTask",
      "description": "Preventive maintenance scheduling",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["ELEVATOR", "GATE", "PUMP", "ELECTRICAL", "OTHER"] },
        "frequency": { "type": "string", "enum": ["WEEKLY", "MONTHLY", "QUARTERLY", "YEARLY"] },
        "lastDoneAt": { "type": "string", "format": "date-time" },
        "nextDueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "OVERDUE"] }
      },
      "required": ["id", "condoId", "title", "category", "frequency", "nextDueDate", "status"]
    },
    "CondoScore": {
      "title": "CondoScore",
      "description": "Intelligent delinquency and health score",
      "type": "object",
      "properties": {
        "condoId": { "type": "string" },
        "score": { "type": "number" },
        "delinquencyRate": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "trends": { "type": "array" }
      },
      "required": ["condoId", "score", "delinquencyRate", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/condos/{condoId}": {
      "schema": "Condo",
      "description": "Condominium data"
    },
    "/condos/{condoId}/residents/{residentId}": {
      "schema": "Resident",
      "description": "Residents within a specific condo"
    },
    "/condos/{condoId}/occurrences/{occurrenceId}": {
      "schema": "Occurrence",
      "description": "Occurrences within a specific condo"
    },
    "/condos/{condoId}/visitors/{visitorId}": {
      "schema": "Visitor",
      "description": "Visitors authorized for a condo"
    },
    "/condos/{condoId}/accessLogs/{logId}": {
      "schema": "AccessLog",
      "description": "Access logs for a condo"
    },
    "/condos/{condoId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages for a condo"
    },
    "/condos/{condoId}/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs for administrative actions"
    },
    "/condos/{condoId}/packages/{packageId}": {
      "schema": "Package",
      "description": "Package delivery tracking"
    },
    "/condos/{condoId}/assemblies/{assemblyId}": {
      "schema": "Assembly",
      "description": "Digital assemblies"
    },
    "/condos/{condoId}/maintenance/{taskId}": {
      "schema": "MaintenanceTask",
      "description": "Maintenance tasks"
    },
    "/condos/{condoId}/stats/score": {
      "schema": "CondoScore",
      "description": "Condo health score"
    }
  }
}
