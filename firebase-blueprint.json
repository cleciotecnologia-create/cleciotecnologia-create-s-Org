{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "login": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "CONDO_ADMIN", "RESIDENT"] },
        "condoId": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Condo": {
      "title": "Condo",
      "description": "Condominium information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "units": { "type": "number" },
        "planId": { "type": "string", "enum": ["BASIC", "PRO", "PREMIUM"] },
        "subscriptionStatus": { "type": "string", "enum": ["ACTIVE", "PAST_DUE", "CANCELED"] },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "planId", "adminId"]
    },
    "Resident": {
      "title": "Resident",
      "description": "Resident of a condominium",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "login": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }
      },
      "required": ["id", "condoId", "name", "unit"]
    },
    "Occurrence": {
      "title": "Occurrence",
      "description": "Condominium occurrence or issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "residentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "IN_PROGRESS", "RESOLVED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "condoId", "residentId", "title", "status"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "Visitor authorized by a resident",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "residentId": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "type": { "type": "string", "enum": ["VISITOR", "SERVICE", "DELIVERY"] },
        "status": { "type": "string", "enum": ["PENDING", "AUTHORIZED", "EXPIRED"] },
        "validUntil": { "type": "string", "format": "date-time" },
        "qrCode": { "type": "string" }
      },
      "required": ["id", "condoId", "residentId", "name", "type", "status", "validUntil"]
    },
    "AccessLog": {
      "title": "AccessLog",
      "description": "Log of entry/exit events",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "condoId": { "type": "string" },
        "visitorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string", "enum": ["ENTRY", "EXIT"] }
      },
      "required": ["id", "condoId", "visitorId", "timestamp", "action"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/condos/{condoId}": {
      "schema": "Condo",
      "description": "Condominium data"
    },
    "/condos/{condoId}/residents/{residentId}": {
      "schema": "Resident",
      "description": "Residents within a specific condo"
    },
    "/condos/{condoId}/occurrences/{occurrenceId}": {
      "schema": "Occurrence",
      "description": "Occurrences within a specific condo"
    },
    "/condos/{condoId}/visitors/{visitorId}": {
      "schema": "Visitor",
      "description": "Visitors authorized for a condo"
    },
    "/condos/{condoId}/accessLogs/{logId}": {
      "schema": "AccessLog",
      "description": "Access logs for a condo"
    }
  }
}
